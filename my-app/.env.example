# Copy to .env.local and fill in secrets (never commit .env.local)

# Vapi Dashboard → Settings → API Keys → Private Key (never paste in chat; rotate if exposed)
VAPI_PRIVATE_API_KEY=

VAPI_ASSISTANT_ID=f5824ccc-9c11-459f-9aed-f05d35bbea23
# Phone number *resource* ID from Vapi (UUID), NOT the +E.164 number
VAPI_PHONE_NUMBER_ID=aa5fea1c-f575-4c68-b99d-6bc7f6d877df

# GoHighLevel workflow webhook (lead + call-completed)
GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/82qC6zKLL60OX6HxfKqD/webhook-trigger/05966dd3-ccab-408e-8180-5f4810cab4c7

# Public base URL of this app (no trailing slash). Examples:
#   Production: https://your-domain.com
#   ngrok:      https://abcd-12-34-56-78.ngrok-free.app   (changes when tunnel restarts)
# In Vapi → assistant/phone Server URL, use exactly:
#   ${PUBLIC_APP_URL}/api/vapi/webhook
# Point ngrok at Next (3000) or nginx (8088), e.g. ngrok http 3000
PUBLIC_APP_URL=https://abcd-12-34-56-78.ngrok-free.app
